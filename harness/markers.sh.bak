#!/usr/bin/env bash
# markers.sh — 마커 레지스트리 (Single Source of Truth)
# 에이전트 출력 마커 포맷: ---MARKER:<NAME>---
# parse_marker()와 Python 훅 모두 이 포맷을 사용한다.

# 마커 정규식 패턴 (bash grep -oEm1용)
MARKER_PATTERN='---MARKER:([A-Z_]+)---'

# 전체 마커 목록 (검증용)
KNOWN_MARKERS=(
  # validator
  PASS FAIL SPEC_MISSING
  PLAN_VALIDATION_PASS PLAN_VALIDATION_FAIL
  DESIGN_REVIEW_PASS DESIGN_REVIEW_FAIL
  BUGFIX_PASS BUGFIX_FAIL
  # test-engineer
  TESTS_PASS TESTS_FAIL TESTS_WRITTEN
  # pr-reviewer
  LGTM CHANGES_REQUESTED
  # security-reviewer
  SECURE VULNERABILITIES_FOUND
  # architect
  LIGHT_PLAN_READY READY_FOR_IMPL
  SPEC_GAP_FOUND SPEC_GAP_RESOLVED
  PRODUCT_PLANNER_ESCALATION_NEEDED TECH_CONSTRAINT_CONFLICT
  # product-planner
  PRODUCT_PLAN_READY PRODUCT_PLAN_UPDATED CLARITY_INSUFFICIENT
  # ux-architect
  UX_FLOW_READY UX_FLOW_ESCALATE
  # validator UX Validation
  UX_REVIEW_PASS UX_REVIEW_FAIL UX_REVIEW_ESCALATE
  # design-critic
  PICK ITERATE ESCALATE
  VARIANTS_APPROVED VARIANTS_ALL_REJECTED
  # harness control
  HARNESS_DONE
  IMPLEMENTATION_ESCALATE
  MERGE_CONFLICT_ESCALATE
)
