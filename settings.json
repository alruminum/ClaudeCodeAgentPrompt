{
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "600000",
    "BASH_MAX_TIMEOUT_MS": "1800000",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_AUTO_COMPACT": "1"
  },
  "permissions": {
    "allow": [
      "WebFetch",
      "Write(~/.claude/**)",
      "Edit(~/.claude/**)",
      "Bash(*)",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_navigate_back",
      "mcp__playwright__browser_screenshot",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_type",
      "mcp__playwright__browser_fill_form",
      "mcp__playwright__browser_hover",
      "mcp__playwright__browser_drag",
      "mcp__playwright__browser_press_key",
      "mcp__playwright__browser_select_option",
      "mcp__playwright__browser_evaluate",
      "mcp__playwright__browser_run_code",
      "mcp__playwright__browser_wait_for",
      "mcp__playwright__browser_handle_dialog",
      "mcp__playwright__browser_file_upload",
      "mcp__playwright__browser_tabs",
      "mcp__playwright__browser_close",
      "mcp__playwright__browser_resize",
      "mcp__playwright__browser_network_requests",
      "mcp__playwright__browser_console_messages",
      "mcp__github__create_issue",
      "mcp__github__get_issue",
      "mcp__github__list_issues",
      "mcp__github__update_issue",
      "mcp__github__add_issue_comment",
      "mcp__github__list_pull_requests",
      "mcp__github__get_pull_request",
      "mcp__github__get_pull_request_comments",
      "mcp__github__get_pull_request_files",
      "mcp__github__get_pull_request_reviews",
      "mcp__github__get_pull_request_status",
      "mcp__github__list_commits",
      "mcp__github__search_issues",
      "mcp__github__search_code",
      "mcp__github__search_repositories",
      "mcp__github__search_users",
      "mcp__github__create_branch",
      "mcp__github__create_pull_request",
      "mcp__pencil"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(rmdir *)",
      "Bash(mkfs *)",
      "Bash(dd *)",
      "Bash(chmod -R 777 *)",
      "Bash(curl * | bash*)",
      "Bash(wget * | bash*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "_meta": "harness",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/harness-router.py auto 2>>/tmp/harness-hook-stderr.log; exit 0",
            "timeout": 30
          }
        ]
      },
      {
        "_meta": "harness",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/harness-review-inject.py 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "_meta": "harness",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/harness-session-start.py auto 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "_meta": "harness",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          }
        ]
      },
      {
        "_meta": "harness",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/harness-review-stop.py 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "_meta": "harness",
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/harness-settings-watcher.py 2>/dev/null || true",
            "timeout": 5
          }
        ]
      },
      {
        "_meta": "harness",
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/post-agent-flags.py 2>/dev/null || true",
            "timeout": 5
          }
        ]
      },
      {
        "_meta": "harness",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/post-commit-cleanup.py 2>/dev/null || true",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/harness-review-trigger.py 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "_meta": "harness",
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/orch-rules-first.py 2>/dev/null || true",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/agent-boundary.py 2>/dev/null || true",
            "timeout": 5
          }
        ]
      },
      {
        "_meta": "harness",
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/orch-rules-first.py 2>/dev/null || true",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/agent-boundary.py 2>/dev/null || true",
            "timeout": 5
          }
        ]
      },
      {
        "_meta": "harness",
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/agent-boundary.py 2>/dev/null || true",
            "timeout": 5
          }
        ]
      },
      {
        "_meta": "harness",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/harness-drift-check.py 2>/dev/null || true",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/commit-gate.py 2>/dev/null || true",
            "timeout": 5
          }
        ]
      },
      {
        "_meta": "harness",
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/agent-gate.py 2>/dev/null || true",
            "timeout": 5
          }
        ]
      },
      {
        "_meta": "harness",
        "matcher": "mcp__github__create_issue",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/issue-gate.py 2>/dev/null || true",
            "timeout": 5
          }
        ]
      },
      {
        "_meta": "harness",
        "matcher": "mcp__github__update_issue",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/issue-gate.py 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "knowledge-skills@apps-in-toss-skills": true,
    "ralph-loop@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "apps-in-toss-skills": {
      "source": {
        "source": "github",
        "repo": "toss/apps-in-toss-skills"
      }
    }
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}